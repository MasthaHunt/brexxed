# ── Required — set BOTH to the same long random string ──────────────────────
# This secret gates the /api/state endpoint.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

API_SECRET=72d1fc267731e8ce50823a35ce0f2bcb525a40fa2cca19f820bdde3ea0f9631b
VITE_API_SECRET=72d1fc267731e8ce50823a35ce0f2bcb525a40fa2cca19f820bdde3ea0f9631b

# ── Database — set automatically by Railway's MySQL plugin ───────────────────
# Do NOT set these manually on Railway; they are injected when the plugin is attached.
# You only need them locally if running the server outside of Railway.

# MYSQLHOST=localhost
# MYSQLPORT=3306
# MYSQLUSER=root
# MYSQLPASSWORD=your-local-password
# MYSQLDATABASE=vaulta

# ── Do NOT set PORT — Railway injects it automatically ───────────────────────
